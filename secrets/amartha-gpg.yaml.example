# Template for: secrets/amartha-gpg.yaml (work key)
#
# Each GPG key lives in its own sops file. Create the real file with:
#   nix run nixpkgs#sops -- secrets/amartha-gpg.yaml
#
# Export then paste:
#   gpg --export-secret-keys --armor 0x32B604FD91055131 > /tmp/amartha.asc

gpg_amartha_key: |
    -----BEGIN PGP PRIVATE KEY BLOCK-----

    PASTE_AMARTHA_GPG_PRIVATE_KEY_HERE

    -----END PGP PRIVATE KEY BLOCK-----
