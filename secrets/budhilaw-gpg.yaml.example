# Template for: secrets/budhilaw-gpg.yaml (personal key)
#
# Each GPG key lives in its own sops file. Create the real file with:
#   nix run nixpkgs#sops -- secrets/budhilaw-gpg.yaml
#
# Export then paste:
#   gpg --export-secret-keys --armor 0xBD838B746BAA8C5F > /tmp/personal.asc
#
# See also: secrets/amartha-gpg.yaml.example for the work key.

gpg_personal_key: |
    -----BEGIN PGP PRIVATE KEY BLOCK-----

    PASTE_PERSONAL_GPG_PRIVATE_KEY_HERE

    -----END PGP PRIVATE KEY BLOCK-----
